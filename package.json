{
  "name": "faultlens-frontend-samples",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:browser",
    "start:browser": "npm run build:browser && node scripts/serve-static.mjs dist/faultlens-browser-sample/browser 4200",
    "start:angular": "ng serve faultlens-angular-sample",
    "build": "npm run build:browser && npm run build:angular",
    "build:browser": "tsc -p tsconfig.browser.json --noEmit && node scripts/build-browser-sample.mjs",
    "build:angular": "ng build faultlens-angular-sample",
    "watch": "ng build faultlens-angular-sample --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@faultlenshq/angular": "0.1.0-beta.2",
    "@faultlenshq/browser": "0.1.0-beta.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "esbuild": "^0.27.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
